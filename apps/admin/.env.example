# Copy to `.env` (gitignored). PUBLIC_* vars are inlined at build time.
# In production, set the same value wherever the admin Worker's build env lives.

# Web3Forms key for the dashboard's "request a change" form. Use the same key
# as the marketing site. Without it the form falls back to a placeholder and
# every submission fails.
PUBLIC_WEB3FORMS_ACCESS_KEY='your-web3forms-key'
