---
import "../styles/global.css";

interface Props {
  title?: string;
  /** Optional accent override (a client's brand color) for scoped tinting. */
  accent?: string;
}

const { title = "Mainstay", accent } = Astro.props;
const bodyStyle = accent ? `--accent: ${accent}` : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <meta name="theme-color" content="#FBF7F1" />
  </head>
  <body class="bg-paper text-ink antialiased" style={bodyStyle}>
    <a class="skip-link" href="#main">Skip to content</a>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
