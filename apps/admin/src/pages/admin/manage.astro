---
// /admin/manage — owner-only roster management. Add/edit/remove client sites
// and their owner emails. Onboarding a client is a write here — no redeploy.
// (Functional version; elevated in the impeccable design pass.)
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { listClients } from "../../lib/roster";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/");

const clients = await listClients(Astro.locals.runtime.env.CLIENTS);
---

<AdminLayout title="Clients — Mainstay">
  <section class="wrap">
    <header class="head">
      <div>
        <p class="eyebrow">Mainstay admin</p>
        <h1>Clients</h1>
      </div>
      <form method="POST" action="/api/auth/logout">
        <button type="submit" class="link">Sign out</button>
      </form>
    </header>

    <div class="grid">
      <section aria-labelledby="roster-h">
        <h2 id="roster-h" class="h2">{clients.length} site{clients.length === 1 ? "" : "s"}</h2>
        {clients.length === 0 && <p class="muted">No clients yet. Add one on the right.</p>}
        <ul class="roster">
          {
            clients.map((c) => (
              <li class="card" data-client={JSON.stringify(c)}>
                <span class="swatch" style={`background:${c.accent}`} aria-hidden="true" />
                <div class="card-body">
                  <p class="card-name">{c.displayName}</p>
                  <p class="card-meta">
                    <code>{c.slug}</code> ·{" "}
                    {c.analytics.kind === "path"
                      ? c.analytics.pathPrefix
                      : `siteTag ${c.analytics.siteTag}`}
                  </p>
                  <p class="card-owners">{c.owners.join(", ")}</p>
                </div>
                <div class="card-actions">
                  <button type="button" class="link edit-btn">Edit</button>
                  <button type="button" class="link danger del-btn" data-slug={c.slug}>
                    Remove
                  </button>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <section aria-labelledby="form-h">
        <h2 id="form-h" class="h2">Add / edit a client</h2>
        <form id="client-form" class="form">
          <label>Display name
            <input name="displayName" type="text" required />
          </label>
          <label>Slug <span class="hint">lowercase, hyphens</span>
            <input name="slug" type="text" required pattern="[a-z0-9\-]+" />
          </label>
          <label>Accent color
            <input name="accent" type="color" value="#b4533a" />
          </label>
          <label>Public site URL <span class="hint">optional</span>
            <input name="siteUrl" type="url" placeholder="https://" />
          </label>

          <fieldset class="fieldset">
            <legend>How is this site's analytics separated?</legend>
            <label class="radio">
              <input type="radio" name="analyticsKind" value="path" checked />
              Subpath under mainstayshop.studio
            </label>
            <label class="sub">Path prefix
              <input name="pathPrefix" type="text" placeholder="/demo/saltworks" />
            </label>
            <label class="radio">
              <input type="radio" name="analyticsKind" value="siteTag" />
              Own domain (its own Web Analytics site)
            </label>
            <label class="sub">Site tag
              <input name="siteTag" type="text" placeholder="cloudflare web-analytics site tag" />
            </label>
          </fieldset>

          <label>Owner emails <span class="hint">one per line or comma-separated</span>
            <textarea name="owners" rows="3" required placeholder="owner@theirshop.com"></textarea>
          </label>

          <p id="form-error" class="error" hidden role="alert"></p>
          <div class="form-actions">
            <button type="submit" class="btn">Save client</button>
            <button type="button" id="reset-btn" class="btn-text">Clear</button>
          </div>
        </form>
      </section>
    </div>
  </section>
</AdminLayout>

<style>
  .wrap { max-width: var(--container-page); margin-inline: auto; padding: 3rem 1.5rem 5rem; }
  .head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; }
  .eyebrow { font-size: 0.75rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-ink-mute); margin: 0 0 0.25rem; }
  h1 { font-family: var(--font-serif); font-size: var(--text-section); margin: 0; }
  .h2 { font-size: 1.1rem; margin: 0 0 1rem; }
  .muted { color: var(--color-ink-mute); }
  .grid { display: grid; gap: 2.5rem; }
  @media (min-width: 900px) { .grid { grid-template-columns: 1fr 1fr; align-items: start; } }
  .roster { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .card { display: grid; grid-template-columns: auto 1fr auto; gap: 0.9rem; align-items: start; background: var(--color-surface); border: 1px solid var(--color-line); border-radius: var(--radius-card); padding: 1rem 1.25rem; }
  .swatch { width: 1.5rem; height: 1.5rem; border-radius: 999px; margin-top: 0.15rem; }
  .card-name { font-weight: 600; margin: 0; }
  .card-meta { color: var(--color-ink-soft); font-size: 0.85rem; margin: 0.2rem 0; }
  .card-meta code { font-size: 0.85em; }
  .card-owners { color: var(--color-ink-mute); font-size: 0.8rem; margin: 0; }
  .card-actions { display: flex; flex-direction: column; gap: 0.35rem; align-items: end; }
  .form { display: flex; flex-direction: column; gap: 1rem; }
  label { display: flex; flex-direction: column; gap: 0.35rem; font-weight: 600; font-size: 0.9rem; }
  .hint { font-weight: 400; color: var(--color-ink-mute); font-size: 0.8rem; }
  input, textarea { border: 1px solid var(--color-line-strong); border-radius: var(--radius-button); padding: 0.6rem 0.75rem; font-size: 1rem; font-family: inherit; background: var(--color-paper); }
  input[type="color"] { padding: 0.2rem; height: 2.6rem; width: 4rem; }
  input:focus-visible, textarea:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
  .fieldset { border: 1px solid var(--color-line); border-radius: var(--radius-button); padding: 1rem; display: flex; flex-direction: column; gap: 0.6rem; }
  legend { font-size: 0.85rem; font-weight: 600; padding: 0 0.4rem; }
  .radio { flex-direction: row; align-items: center; gap: 0.5rem; font-weight: 500; }
  .sub { margin-left: 1.5rem; font-weight: 400; }
  .form-actions { display: flex; gap: 1rem; align-items: center; }
  .link { background: none; border: 0; color: var(--color-ink-soft); text-decoration: underline; cursor: pointer; padding: 0; font-size: 0.85rem; }
  .link:hover { color: var(--color-ink); }
  .danger { color: var(--color-accent-deep); }
  .error { color: var(--color-accent-deep); background: var(--color-accent-soft); border-radius: var(--radius-button); padding: 0.6rem 0.75rem; margin: 0; font-size: 0.9rem; }
</style>

<script>
  const form = document.getElementById("client-form") as HTMLFormElement;
  const errorEl = document.getElementById("form-error")!;
  const kindRadios = form.querySelectorAll<HTMLInputElement>('input[name="analyticsKind"]');

  function currentKind(): string {
    return (
      Array.from(kindRadios).find((r) => r.checked)?.value ?? "path"
    );
  }

  function set(name: string, value: string) {
    const el = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null;
    if (el) el.value = value;
  }

  // Populate the form when "Edit" is clicked on a card.
  document.querySelectorAll<HTMLButtonElement>(".edit-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const li = btn.closest("li")!;
      const c = JSON.parse(li.dataset.client!);
      set("displayName", c.displayName);
      set("slug", c.slug);
      // Slug is the record key — lock it on edit so saving can't fork a
      // duplicate. To rename, remove the client and add it again.
      const slugInput = form.elements.namedItem("slug") as HTMLInputElement;
      slugInput.readOnly = true;
      slugInput.title = "To rename, remove this client and add it again.";
      set("accent", c.accent);
      set("siteUrl", c.siteUrl ?? "");
      set("owners", c.owners.join("\n"));
      const kind = c.analytics.kind;
      form.querySelector<HTMLInputElement>(`input[name="analyticsKind"][value="${kind}"]`)!.checked = true;
      set("pathPrefix", kind === "path" ? c.analytics.pathPrefix : "");
      set("siteTag", kind === "siteTag" ? c.analytics.siteTag : "");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      form.scrollIntoView({ behavior: reduce ? "auto" : "smooth" });
    });
  });

  // Delete.
  document.querySelectorAll<HTMLButtonElement>(".del-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const slug = btn.dataset.slug!;
      if (!confirm(`Remove ${slug}? Owners lose access.`)) return;
      const res = await fetch(`/api/clients/${slug}`, { method: "DELETE" });
      if (res.ok) location.reload();
      else alert("Could not remove that client.");
    });
  });

  document.getElementById("reset-btn")!.addEventListener("click", () => {
    form.reset();
    const slugInput = form.elements.namedItem("slug") as HTMLInputElement;
    slugInput.readOnly = false;
    slugInput.removeAttribute("title");
    errorEl.hidden = true;
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.hidden = true;
    const fd = new FormData(form);
    const payload = {
      slug: fd.get("slug"),
      displayName: fd.get("displayName"),
      accent: fd.get("accent"),
      siteUrl: fd.get("siteUrl"),
      analyticsKind: currentKind(),
      pathPrefix: fd.get("pathPrefix"),
      siteTag: fd.get("siteTag"),
      owners: fd.get("owners"),
    };
    const res = await fetch("/api/clients", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = (await res.json()) as { ok?: boolean; error?: string };
    if (res.ok && data.ok) {
      location.reload();
    } else {
      errorEl.textContent = data.error ?? "Could not save.";
      errorEl.hidden = false;
    }
  });
</script>
