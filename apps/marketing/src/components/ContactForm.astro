---
// ContactForm — 5-field form posting to Web3Forms.
//
// Set PUBLIC_WEB3FORMS_ACCESS_KEY in an .env file (or replace the fallback
// below). Get a key at https://web3forms.com — free, unlimited submissions,
// no account required.
//
// Fields: name, email, shop name + city, existing site URL (optional),
// free-text "tell me about your shop".

const WEB3FORMS_ACCESS_KEY =
  import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ??
  "REPLACE_WITH_YOUR_WEB3FORMS_KEY";
---

<section id="contact" class="section-y bg-surface">
  <div class="container-page grid gap-x-12 gap-y-10 md:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)]">
    <div>
      <p class="text-ink-mute text-sm tracking-wide uppercase mb-3">
        Get in touch
      </p>
      <h2 class="font-serif text-[clamp(1.75rem,3.5vw,2.25rem)] leading-[1.15] tracking-[-0.01em] text-balance max-w-[16ch]">
        Tell me about your shop.
      </h2>
      <p class="text-ink-soft mt-4 max-w-[40ch] text-[1.0625rem] leading-[1.6] text-pretty">
        Send a few details and I'll get back to you within a day or two —
        usually the same day. There's no obligation, no auto-responder,
        no sales pipeline. Just me reading your note.
      </p>
      <p class="text-ink-soft mt-6 text-[0.9375rem]">
        Or just email me at
        <a
          href="mailto:hello@mainstayshop.studio"
          class="text-ink font-medium decoration-line-strong hover:decoration-accent"
        >
          hello@mainstayshop.studio
        </a>.
      </p>
    </div>

    <form
      id="contact-form"
      method="POST"
      action="https://api.web3forms.com/submit"
      class="bg-paper border-line space-y-5 rounded-[var(--radius-card)] border p-6 md:p-8"
    >
      <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
      <input type="hidden" name="subject" value="New Mainstay inquiry" />
      <input type="hidden" name="from_name" value="Mainstay website" />
      {/* Honeypot — bots fill in invisible fields, real visitors don't. */}
      <input
        type="checkbox"
        name="botcheck"
        tabindex="-1"
        autocomplete="off"
        style="position:absolute;left:-9999px;width:0;height:0;opacity:0"
        aria-hidden="true"
      />

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="name" class="block text-sm font-medium">
            Your name
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="border-line bg-paper focus:border-accent mt-1.5 block w-full rounded-[var(--radius-button)] border px-3 py-2.5 text-[1rem] leading-snug outline-none"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="border-line bg-paper focus:border-accent mt-1.5 block w-full rounded-[var(--radius-button)] border px-3 py-2.5 text-[1rem] leading-snug outline-none"
          />
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)]">
        <div>
          <label for="shop" class="block text-sm font-medium">
            Shop name
          </label>
          <input
            id="shop"
            name="shop"
            type="text"
            class="border-line bg-paper focus:border-accent mt-1.5 block w-full rounded-[var(--radius-button)] border px-3 py-2.5 text-[1rem] leading-snug outline-none"
          />
        </div>
        <div>
          <label for="city" class="block text-sm font-medium">
            City / region
          </label>
          <input
            id="city"
            name="city"
            type="text"
            class="border-line bg-paper focus:border-accent mt-1.5 block w-full rounded-[var(--radius-button)] border px-3 py-2.5 text-[1rem] leading-snug outline-none"
          />
        </div>
      </div>

      <div>
        <label for="website" class="block text-sm font-medium">
          Existing site URL
          <span class="text-ink-mute font-normal">(if any)</span>
        </label>
        <input
          id="website"
          name="website"
          type="url"
          inputmode="url"
          placeholder="https://"
          autocomplete="url"
          class="border-line bg-paper focus:border-accent mt-1.5 block w-full rounded-[var(--radius-button)] border px-3 py-2.5 text-[1rem] leading-snug outline-none"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium">
          Tell me about your shop
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="border-line bg-paper focus:border-accent mt-1.5 block w-full rounded-[var(--radius-button)] border px-3 py-2.5 text-[1rem] leading-snug outline-none"
        ></textarea>
        <p class="text-ink-mute mt-2 text-xs">
          What you sell, what you're hoping for, and how soon — whatever
          comes to mind is fine.
        </p>
      </div>

      <p
        id="contact-error"
        hidden
        role="alert"
        class="text-accent-deep border-accent bg-accent-soft/40 rounded-[var(--radius-button)] border px-3 py-2 text-sm"
      >
      </p>

      <button
        type="submit"
        class="bg-accent hover:bg-accent-deep text-paper inline-flex w-full items-center justify-center rounded-[var(--radius-button)] px-5 py-3 font-medium transition-colors disabled:opacity-60 sm:w-auto"
      >
        Send it over
      </button>
    </form>

    <div
      id="contact-success"
      hidden
      role="status"
      aria-live="polite"
      class="bg-paper border-line flex flex-col gap-4 rounded-[var(--radius-card)] border p-6 md:p-8"
    >
      <p class="font-serif text-2xl leading-snug text-balance">
        Thanks — got your note.
      </p>
      <p class="text-ink-soft text-[1.0625rem] leading-[1.6] text-pretty">
        I'll be in touch within a day or two, usually the same day. If you
        don't hear back, check your spam folder — or just email me at
        <a
          href="mailto:hello@mainstayshop.studio"
          class="text-ink font-medium decoration-line-strong hover:decoration-accent"
        >
          hello@mainstayshop.studio
        </a>.
      </p>
      <button
        type="button"
        id="send-another"
        class="border-ink hover:bg-ink hover:text-paper inline-flex w-fit items-center rounded-[var(--radius-button)] border px-4 py-2 text-sm font-medium transition-colors"
      >
        Send another message
      </button>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const successEl = document.getElementById("contact-success");
  const errorEl = document.getElementById("contact-error");
  const sendAnotherBtn = document.getElementById("send-another");

  function showError(message: string) {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.hidden = false;
  }

  function hideError() {
    if (!errorEl) return;
    errorEl.hidden = true;
    errorEl.textContent = "";
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form) return;

    const submitBtn = form.querySelector<HTMLButtonElement>(
      'button[type="submit"]'
    );
    const originalLabel = submitBtn?.textContent ?? "Send it over";

    hideError();
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";
    }

    try {
      const formData = new FormData(form);
      const payload: Record<string, FormDataEntryValue> = {};
      formData.forEach((value, key) => {
        payload[key] = value;
      });

      const response = await fetch(form.action, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(payload),
      });

      const result = (await response.json()) as {
        success?: boolean;
        message?: string;
      };

      if (response.ok && result.success) {
        form.reset();
        form.hidden = true;
        if (successEl) successEl.hidden = false;
      } else {
        showError(
          result.message ??
            "Something went wrong sending your note. Please try again, or email me directly at hello@mainstayshop.studio."
        );
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      }
    } catch {
      showError(
        "Couldn't reach the form service. Please try again, or email me directly at hello@mainstayshop.studio."
      );
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    }
  });

  sendAnotherBtn?.addEventListener("click", () => {
    if (!form || !successEl) return;
    successEl.hidden = true;
    form.hidden = false;
    form.querySelector<HTMLInputElement>('input[name="name"]')?.focus();
  });
</script>
