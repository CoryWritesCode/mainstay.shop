---
// Hero — the page's first impression. Typographic, cream-backed, no stock photo.
---

<section class="section-y relative overflow-hidden">
  <div class="container-page">
    <p class="text-ink-mute mb-10 flex items-center gap-3 font-sans text-sm tracking-wide uppercase">
      <span class="bg-accent inline-block size-2 rounded-full" aria-hidden="true"></span>
      Mainstay
    </p>

    <h1 class="font-serif text-[clamp(2.5rem,6vw,3.75rem)] leading-[1.05] tracking-[-0.02em] text-balance max-w-[18ch]">
      A real website for your shop —
      <span class="relative inline-block">
        built by a human.
        <svg
          class="text-accent absolute -bottom-2 left-0 h-3 w-full"
          viewBox="0 0 300 12"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 8c40-4 80-4 120-2s80 4 120 2 50-2 56-4"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
          ></path>
        </svg>
      </span>
    </h1>

    <p class="text-ink-soft mt-8 max-w-[42ch] text-[clamp(1.0625rem,1.6vw,1.25rem)] leading-[1.55] text-pretty">
      Mainstay designs, builds, hosts, and looks after websites for local shops.
      No templates to wrestle with. No surprise fees. Just an honest price and
      somebody on the other end of the phone.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3">
      <a
        href="#contact"
        class="bg-accent hover:bg-accent-deep text-paper inline-flex items-center gap-2 rounded-[var(--radius-button)] px-5 py-3 font-medium no-underline transition-colors"
      >
        Tell me about your shop
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="#pricing"
        class="text-ink-soft hover:text-ink decoration-line-strong hover:decoration-accent font-medium"
      >
        See pricing
      </a>
    </div>

    <p class="text-ink-mute mt-12 text-sm">
      Local shops, anywhere in the US · Pricing starts at $1,500 setup + $69/mo
    </p>
  </div>
</section>
